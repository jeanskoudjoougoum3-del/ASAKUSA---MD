# --- Identité du bot ---
PREFIX=.
BOT_VERSION=1.0.0
BOT_MODE=public

# --- Numéro du propriétaire (utilisé pour les commandes réservées) ---
# Format : indicatif + numéro, SANS le +, SANS espaces
OWNER_NUMBER=22899344951

# --- Numéro utilisé pour générer le CODE DE PARRAINAGE (pairing code) ---
# C'est le numéro WhatsApp qui hébergera le bot. Souvent le même que OWNER_NUMBER.
PAIRING_NUMBER=22899344951

# --- Clés API optionnelles (laisser vide si non utilisées) ---
# Nécessaire pour .removbg : clé gratuite sur https://www.remove.bg/api
REMOVEBG_API_KEY=

# Nécessaire pour .realism (transformation IA d'image) : Stability AI, Replicate, etc.
AI_IMAGE_API_KEY=